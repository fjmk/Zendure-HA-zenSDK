views:
  - type: sections
    max_columns: 3
    title: Zendure
    path: zendure
    sections:
      - type: grid
        cards:
          - type: heading
            icon: mdi:battery
            heading_style: title
            badges:
              - type: entity
                show_state: true
                show_icon: true
                entity: sensor.zendure_2400_ac_vermogen_aansturing
                tap_action:
                  action: more-info
                color: '#01a180'
              - type: entity
                show_state: true
                show_icon: true
                entity: sensor.zendure_2400_ac_laadpercentage
                color: '#01a180'
                tap_action:
                  action: more-info
              - type: entity
                show_state: true
                show_icon: true
                entity: sensor.zendure_2400_ac_relais_schakelingen_totaal_vandaag
                icon: mdi:swap-vertical-bold
                color: '#01a180'
                tap_action:
                  action: more-info
            heading: Batterij
          - type: markdown
            content: >
              {% set modus =
              states('input_select.zendure_2400_ac_modus_selecteren') %}

              {% if modus == 'Standby' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Zet de batterij volledig in
              standby en **Opslagmodus** zal naar **Opslaan in Flash** gaan.
              Hierdoor is het ook 0 watt op een KWH MID Meter.   


              100% standby, de batterij gebruikt nog 0,2 kWh per dag.

              {% elif modus == 'Handmatig' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Via **Handmatig Vermogen**
              kun je zelf aangeven wat de batterij doet. -watt voor ontladen en
              +watt voor opladen.   

              {% elif modus == 'Nul op de meter' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Constant nul op de meter
              behouden (-xx watt bij opladen en -xx watt bij ontladen). Je kunt
              het opladen finetunen via **Oplaadmarge ⚙️** waarbij je aangeeft
              hoeveel buffer/marge de batterij moet behouden tot 0 watt. Het
              ontladen kun je finetunen via **Ontlaadmarge ⚙️** waarbij je
              aangeeft hoeveel extra watt de batterij moet ontladen boven op nul
              op de meter. Beide zijn handig om vaste kleine schommelingen in je
              huisverbruik standaard te compenseren.


              Ook kun je zelf instellen wanneer de batterij start met opladen
              via **Opladen Starten Bij ⚙️** en wanneer hij start met ontladen
              via **Ontladen starten bij ⚙️** 

              {% elif modus == 'Dynamisch NOM' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> ⚠️ Let op: Alleen te
              gebruiken met Nordpool sensor ⚙️. 


              Vul als eerste in hoeveel uren je goedkoop zou willen laden per
              dag via **Goedkoopste Periodes** dit is bijvoorbeeld 3 uur.
              Vervolgens vul je de overige duurste uren in via **Duurste
              Periodes** dit is bijvoorbeeld 3 uur. Wanneer nu **Goedkoopste
              Periodes** op JA staat zal er opgeladen worden indien **Spread**
              hoger is dan **Minimale Spread ⚙️**. Wanneer **Goedkoopste
              Periodes** erg lang op JA staat zal de batterij pas weer gaan
              laden wanneer de batterij ontladen is tot 90%. De batterij zal na
              laden constant nul op de meter behouden (-xx watt bij opladen en
              -xx watt bij ontladen).

              {% elif modus == 'Dynamisch NOM (Duur)' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> ⚠️ Let op: Alleen te
              gebruiken met Nordpool sensor ⚙️. 


              Vul als eerste in hoeveel uren je goedkoop zou willen laden per
              dag via **Goedkoopste Periodes** dit is bijvoorbeeld 3 uur.
              Vervolgens vul je de overige duurste uren in via **Duurste
              Periodes** dit is bijvoorbeeld 3 uur. Wanneer nu **Goedkoopste
              Periodes** op JA staat zal er opgeladen worden indien **Spread**
              hoger is dan **Minimale Spread ⚙️**. Wanneer **Goedkoopste
              Periodes** erg lang op JA staat zal hij pas weer gaan laden
              wanneer de batterij ontladen is tot 90%. Mocht er nog ruimte zijn
              om meer op te laden zal de batterij dit bij teruglevering gaan
              doen. Wanneer **Goedkoopste Periodes** op JA staat zal de batterij
              alleen slim gaan ontladen en de rest van de tijd staat de batterij
              in standby.

              {% elif modus == 'Dynamisch Handelen' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> ⚠️ Let op: Alleen te
              gebruiken met Nordpool sensor ⚙️. 


              Vul als eerste in hoeveel uren je goedkoop zou willen laden per
              dag via **Goedkoopste Periodes** dit is bijvoorbeeld 3 uur.
              Vervolgens vul je de overige duurste uren in via **Duurste
              Periodes** dit is bijvoorbeeld 3 uur. Wanneer nu **Goedkoopste
              Periodes** op JA staat zal er opgeladen worden indien **Spread**
              hoger is dan **Minimale Spread ⚙️**. Wanneer **Goedkoopste
              Periodes** erg lang op JA staat zal de batterij pas weer gaan
              laden wanneer de batterij ontladen is tot 90%. Wanneer **Duurste
              Periodes** op JA staat zal de batterij op maximaal vermogen gaan
              ontladen en de rest van de tijd staat de batterij in standby.

              {% elif modus == 'Dynamisch Handelen + NOM' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> ⚠️ Let op: Alleen te
              gebruiken met Nordpool sensor ⚙️. 


              Vul als eerste in hoeveel uren je goedkoop zou willen laden per
              dag via **Goedkoopste Periodes** dit is bijvoorbeeld 3 uur.
              Vervolgens vul je de overige duurste uren in via **Duurste
              Periodes** dit is bijvoorbeeld 3 uur. Wanneer nu **Goedkoopste
              Periodes** op JA staat zal er opgeladen worden indien **Spread**
              hoger is dan **Minimale Spread ⚙️**. Wanneer **Goedkoopste
              Periodes** erg lang op JA staat zal de batterij pas weer gaan
              laden wanneer de batterij ontladen is tot 90%. Wanneer **Duurste
              Periodes** op JA staat zal de batterij op maximaal vermogen gaan
              ontladen en de rest van de tijd **Nul op de meter**.

              {% elif modus == 'Alleen slim ontladen' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Identiek aan **Nul op de
              meter**, alleen zonder opladen.

              {% elif modus == 'Alleen slim opladen' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Identiek aan **Nul op de
              meter**, alleen zonder ontladen.

              {% elif modus == 'Snel opladen' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Snel opladen op maximaal
              vermogen wat ingesteld staat bij **Max. Oplaadvermogen ⚙️**.

              {% elif modus == 'Snel ontladen' %} <ha-alert
              alert-type="info">Helptekst</ha-alert> Snel ontladen op maximaal
              vermogen wat ingesteld staat bij **Max. Ontlaadvermogen ⚙️**.

              {% else %} <ha-alert alert-type="warning">Helptekst</ha-alert>
              Selecteer een modus om uitleg te zien. {% endif %}
            text_only: true
            visibility:
              - condition: state
                entity: input_boolean.help_tonen_op_dashboard
                state: 'on'
          - type: entities
            entities:
